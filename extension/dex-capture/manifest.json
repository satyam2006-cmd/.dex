{
  "manifest_version": 3,
  "name": ".dex Capture Bridge",
  "version": "1.0.0",
  "description": "Sends open browser tabs to the local .dex CLI for workspace snapshots.",
  "permissions": [
    "alarms",
    "tabs"
  ],
  "host_permissions": [
    "http://127.0.0.1:17654/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": ".dex Capture"
  }
}
